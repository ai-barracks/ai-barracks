#!/usr/bin/env bash
# aib — AI Barracks CLI v1.2.0
# Usage: aib <command> [args]
#
# Commands:
#   init [path]                              Initialize barrack + configure hooks
#   start <client> [task] [--skip-permissions]  Start LLM session with tracking
#   hook start <client>                      (Internal) Called by CLI SessionStart hooks
#   hook end <client>                        (Internal) Called by CLI SessionEnd hooks
#   hook continue <session_id>               Continue a session from another CLI
#   barracks [list|remove|route|refresh]     Manage registered barracks
#   status                                   Show active sessions and wiki stats
#   sync [--dry-run] [path]                  Sync templates + protocol to barrack
#   council [-r N] [-m MODE] "topic"         Run multi-LLM debate council
#   version                                  Show version

set -euo pipefail

AIB_VERSION="1.2.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE_DIR="$(cd "$SCRIPT_DIR/../templates" && pwd)"

# --- Colors (stderr only for hooks — stdout is for LLM context) ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_ok()   { echo -e "${GREEN}[OK]${NC}   $1" >&2; }
log_info() { echo -e "${CYAN}[INFO]${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_err()  { echo -e "${RED}[ERR]${NC}  $1" >&2; }

# --- Helpers ---
# validate_claude_settings — scan .claude/settings*.json for unmatched quotes in
# Bash(...) permission patterns. Claude Code 2.1.118 renders an invisible
# Settings dialog in some PTY environments (e.g. Tauri/portable_pty inside
# CommandCenter) when these are present, gating all stdin and making the TUI
# appear frozen. Print warnings before launch so the user can fix the file.
validate_claude_settings() {
    command -v python3 &>/dev/null || return 0
    local out
    out=$(python3 - <<'PY' 2>/dev/null
import json, os
broken = []
for path in ('.claude/settings.local.json', '.claude/settings.json'):
    if not os.path.isfile(path):
        continue
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        continue
    allow = (data.get('permissions') or {}).get('allow') or []
    for entry in allow:
        if not (isinstance(entry, str) and entry.startswith('Bash(') and entry.endswith(')')):
            continue
        inner = entry[5:-1]
        if inner.count("'") % 2 == 1 or inner.count('"') % 2 == 1:
            broken.append(f"{path}: {entry}")
for b in broken:
    print(b)
PY
)
    [ -z "$out" ] && return 0
    local count
    count=$(printf '%s\n' "$out" | wc -l | tr -d ' ')
    log_warn "${count} broken Bash() permission pattern(s) detected in .claude/settings*.json:"
    printf '%s\n' "$out" | head -3 | while IFS= read -r line; do
        log_warn "  ${line}"
    done
    log_warn "Claude 2.1.118 may render an invisible Settings dialog and ignore all stdin (incl. Ctrl+C) inside CommandCenter PTY."
    log_warn "Fix: balance quotes in .claude/settings.local.json. See https://github.com/ai-barracks/ai-barracks/blob/main/docs/troubleshooting.md"
    return 0
}

client_name() {
    case "$1" in
        claude) echo "Claude Code" ;;
        gemini) echo "Gemini CLI" ;;
        codex)  echo "Codex CLI" ;;
        slack)  echo "Slack Bot" ;;
        *)      echo "$1" ;;
    esac
}

make_session_id() {
    echo "${1}-$(date +%Y%m%d-%H%M)"
}

ensure_sessions_md() {
    if [ ! -f "SESSIONS.md" ]; then
        cp "$TEMPLATE_DIR/SESSIONS.md" "SESSIONS.md"
    fi
}

ensure_sessions_dir() {
    mkdir -p sessions
}

# --- Global barrack registry (~/.aib/barracks.json) ---
AIB_REGISTRY="$HOME/.aib/barracks.json"

ensure_registry() {
    mkdir -p "$HOME/.aib"
    [ -f "$AIB_REGISTRY" ] || echo '[]' > "$AIB_REGISTRY"
}

register_barrack() {
    local path="$1"
    ensure_registry

    # Extract metadata from barrack files
    local name
    name=$(basename "$path")
    local description=""
    local expertise=""
    local topics=""

    if [ -f "$path/agent.yaml" ]; then
        description=$(grep "^description:" "$path/agent.yaml" 2>/dev/null | sed 's/^description: *"*//;s/"*$//' || true)
    fi
    if [ -f "$path/SOUL.md" ]; then
        expertise=$(sed -n '/^## Expertise/,/^## /{/^- /p;}' "$path/SOUL.md" 2>/dev/null | sed 's/^- //' | tr '\n' ',' | sed 's/,$//' || true)
    fi
    if [ -f "$path/wiki/Index.md" ]; then
        topics=$(grep "^|" "$path/wiki/Index.md" 2>/dev/null | grep -v "Topic\|---" | awk -F'|' '{print $2}' | tr -d ' ' | tr '\n' ',' | sed 's/,$//' || true)
    fi

    # Remove existing entry for this path, then add new
    local tmp="${AIB_REGISTRY}.tmp"
    local tmp2="${AIB_REGISTRY}.tmp2"
    jq --arg p "$path" '[.[] | select(.path != $p)]' "$AIB_REGISTRY" > "$tmp" 2>/dev/null || echo '[]' > "$tmp"
    jq --arg p "$path" --arg n "$name" --arg d "$description" --arg e "$expertise" --arg t "$topics" \
        '. + [{"path": $p, "name": $n, "description": $d, "expertise": $e, "topics": $t}]' \
        "$tmp" > "$tmp2" 2>/dev/null
    if jq empty "$tmp2" 2>/dev/null; then
        mv "$tmp2" "$AIB_REGISTRY"
    else
        log_err "Failed to update barracks.json — original preserved"
        rm -f "$tmp2"
    fi
    rm -f "$tmp"
    log_ok "Barrack registered in ~/.aib/barracks.json"
}

unregister_barrack() {
    local path="$1"
    ensure_registry
    local tmp="${AIB_REGISTRY}.tmp"
    jq --arg p "$path" '[.[] | select(.path != $p)]' "$AIB_REGISTRY" > "$tmp" 2>/dev/null || true
    if jq empty "$tmp" 2>/dev/null; then
        mv "$tmp" "$AIB_REGISTRY"
    else
        log_err "Failed to update barracks.json — original preserved"
        rm -f "$tmp"
        return 1
    fi
    log_ok "Barrack unregistered: $path"
}

# --- Strip ANSI codes from raw capture ---
strip_ansi() {
    sed 's/\x1B\[[0-9;]*[a-zA-Z]//g; s/\x1B[()][AB012]//g; s/\r//g' "$1" | \
        grep -v '^[[:space:]]*$' | head -500
}

# --- Summarize session using LLM ---
summarize_session() {
    local session_id="$1"
    local ctx_file="$2"
    local raw_file="$3"

    # Strip ANSI and truncate
    local clean_file="sessions/${session_id}.txt"
    strip_ansi "$raw_file" > "$clean_file" 2>/dev/null || true

    if [ ! -s "$clean_file" ]; then
        rm -f "$clean_file" "$raw_file"
        return 0
    fi

    # Use claude -p to summarize (cheap, fast)
    local summary
    summary=$(claude -p "다음은 AI CLI 세션의 원본 기록이다. 이 세션에서 수행된 작업을 정리하라.

형식:
## Log
- [HH:MM] <사용자 요청 요약> → <수행 결과>
(실제 시간을 추정하여 기록)

## Decisions
- 주요 결정 사항 (없으면 생략)

## Wiki Extractions
다음 기준으로 wiki/RULES에 남길 지식을 판단하라:
- 아키텍처 결정, 배포 절차, 디버깅 패턴, 코드 구조 → wiki 토픽
- 실수에서 학습한 규칙, 사용자 교정, 반복 지시 → RULES.md
- Format: - {파일} — {추출 내용 한 줄}
- 해당 없으면 분류별 사유 기술 (예: \"(없음 — wiki: 단순 파일 수정 / RULES: 교정 없음)\")

원본 기록:
$(head -300 "$clean_file")" --output-format text --model claude-sonnet-4-6 2>/dev/null || true)

    if [ -n "$summary" ]; then
        # Replace empty sections in session file with LLM summary
        local tmp="${ctx_file}.tmp"
        # Keep header, replace from ## Log onwards
        sed -n '1,/^## Log/p' "$ctx_file" > "$tmp"
        echo "$summary" | sed -n '/^## Log/,$ p' | tail -n +2 >> "$tmp" 2>/dev/null || true

        # Append auto-summary
        local log_count
        log_count=$(grep -c "^- \[" "$tmp" 2>/dev/null || echo "0")
        {
            echo ""
            echo "## Summary (auto-generated)"
            echo "- Source: LLM summarization of raw session capture"
            echo "- Log entries: ${log_count}"
            echo "- Duration: $(grep '^\- \*\*Started\*\*:' "$ctx_file" | sed 's/.*: //') ~ $(date '+%Y-%m-%d %H:%M')"
        } >> "$tmp"

        mv "$tmp" "$ctx_file"
        log_info "Session summarized: ${log_count} log entries extracted"
    fi

    # Cleanup raw files
    rm -f "$raw_file" "$clean_file"
}

# --- Stale cleanup (>2h) ---
cleanup_stale() {
    [ ! -f "SESSIONS.md" ] && return 0
    local now_epoch year stale_ids=""
    now_epoch=$(date +%s)
    year=$(date +%Y)

    # Find stale session IDs
    for sid in $(grep "^| [a-z]" "SESSIONS.md" 2>/dev/null | awk -F'|' '{print $2}' | tr -d ' '); do
        local last_update
        last_update=$(grep "^| ${sid} " "SESSIONS.md" | awk -F'|' '{print $5}' | tr -d ' ')
        [ -z "$last_update" ] && continue
        local epoch
        epoch=$(date -j -f "%Y-%m-%d %H:%M" "${year}-${last_update}" +%s 2>/dev/null || echo "0")
        if [ "$epoch" -gt 0 ] && [ $((now_epoch - epoch)) -gt 7200 ]; then
            stale_ids="${stale_ids} ${sid}"
            # Mark session file as interrupted
            if [ -f "sessions/${sid}.md" ]; then
                sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: interrupted/' "sessions/${sid}.md" 2>/dev/null || true
                sed -i '' "s/^- \*\*Ended\*\*: (active)/- **Ended**: $(date '+%Y-%m-%d %H:%M') (stale)/" "sessions/${sid}.md" 2>/dev/null || true
            fi
        fi
    done

    # Remove stale entries
    if [ -n "$stale_ids" ]; then
        local tmp="SESSIONS.md.tmp"
        cp "SESSIONS.md" "$tmp"
        for sid in $stale_ids; do
            grep -v "^| ${sid} " "$tmp" > "${tmp}.2" 2>/dev/null || true
            mv "${tmp}.2" "$tmp"
        done
        mv "$tmp" "SESSIONS.md"
        log_info "Cleaned stale sessions:${stale_ids}"
    fi
    return 0
}

# ============================================================
# aib init (v2 — includes hook auto-registration)
# ============================================================
cmd_init() {
    local target="${1:-.}"
    if [ ! -d "$target" ]; then
        mkdir -p "$target"
    fi
    target="$(cd "$target" && pwd)"

    echo -e "${CYAN}AI Barracks v${AIB_VERSION}${NC}" >&2
    echo "Initializing workspace at: $target" >&2
    echo "" >&2

    # 1. SESSIONS.md
    if [ ! -f "$target/SESSIONS.md" ]; then
        cp "$TEMPLATE_DIR/SESSIONS.md" "$target/SESSIONS.md"
        log_ok "SESSIONS.md created"
    else
        log_warn "SESSIONS.md already exists, skipping"
    fi

    # 2. sessions/ directory
    mkdir -p "$target/sessions"
    log_ok "sessions/ directory created"

    # 3. wiki/
    if [ ! -d "$target/wiki" ]; then
        mkdir -p "$target/wiki/topics"
        cp "$TEMPLATE_DIR/wiki/Index.md" "$target/wiki/Index.md"
        cp "$TEMPLATE_DIR/wiki/Log.md" "$target/wiki/Log.md"
        log_ok "wiki/ directory created"
    else
        log_warn "wiki/ already exists, skipping"
    fi

    # 4. .gitignore
    local gitignore="$target/.gitignore"
    # 4a. v1.2.0: scaffold .gitignore from template if absent
    if [ ! -f "$gitignore" ] && [ -f "$TEMPLATE_DIR/.gitignore" ]; then
        cp "$TEMPLATE_DIR/.gitignore" "$gitignore"
        log_ok "Scaffolded .gitignore"
    fi
    local needs_update=false
    if [ -f "$gitignore" ]; then
        grep -q "^SESSIONS.md$" "$gitignore" || needs_update=true
    else
        needs_update=true
    fi
    if $needs_update; then
        echo -e "\n# MAP (ephemeral session index)\nSESSIONS.md" >> "$gitignore"
        log_ok "Updated .gitignore (SESSIONS.md)"
    fi

    # 5. agent.yaml (GitAgent 호환)
    local ws_name
    ws_name=$(basename "$target")
    if [ ! -f "$target/agent.yaml" ]; then
        sed "s|{{WORKSPACE_NAME}}|${ws_name}|g" "$TEMPLATE_DIR/agent.yaml" > "$target/agent.yaml"
        log_ok "agent.yaml created"
    else
        log_warn "agent.yaml already exists, skipping"
    fi

    # 6. SOUL.md (에이전트 정체성)
    if [ ! -f "$target/SOUL.md" ]; then
        sed "s|{{WORKSPACE_NAME}}|${ws_name}|g" "$TEMPLATE_DIR/SOUL.md" > "$target/SOUL.md"
        log_ok "SOUL.md created"
    else
        log_warn "SOUL.md already exists, skipping"
    fi

    # 7. RULES.md (행동 규칙)
    if [ ! -f "$target/RULES.md" ]; then
        cp "$TEMPLATE_DIR/RULES.md" "$target/RULES.md"
        log_ok "RULES.md created"
    else
        log_warn "RULES.md already exists, skipping"
    fi

    # 8. Inject protocol
    inject_protocol "$target"

    # 9. Register in global barrack registry
    register_barrack "$target"

    # 10. Auto-configure CLI hooks
    echo "" >&2
    configure_hooks

    echo "" >&2
    log_ok "Barrack initialized!"
    echo "" >&2
    echo "Usage:" >&2
    echo "  aib start claude \"your task\"    Start a tracked session" >&2
    echo "  aib status                       Show active sessions" >&2
    echo "  aib hook continue <session_id>   Continue another session" >&2
}

# ============================================================
# Hook auto-configuration
# ============================================================
configure_hooks() {
    log_info "Detecting installed CLIs and configuring hooks..."

    # Claude Code
    if command -v claude &>/dev/null; then
        local claude_settings="$HOME/.claude/settings.json"
        if [ -f "$claude_settings" ]; then
            if grep -q "aib hook" "$claude_settings" 2>/dev/null; then
                log_warn "Claude hooks already configured"
            else
                # Use jq to add hooks if available, otherwise inform user
                if command -v jq &>/dev/null; then
                    local tmp="${claude_settings}.tmp"
                    jq '.hooks = (.hooks // {}) |
                        .hooks.SessionStart = (.hooks.SessionStart // []) + [{"matcher": "", "hooks": [{"type": "command", "command": "aib hook start claude"}]}] |
                        .hooks.SessionEnd = (.hooks.SessionEnd // []) + [{"matcher": "", "hooks": [{"type": "command", "command": "aib hook end claude"}]}]' \
                        "$claude_settings" > "$tmp" && mv "$tmp" "$claude_settings"
                    log_ok "Claude Code hooks configured (SessionStart + SessionEnd)"
                else
                    log_warn "jq not found — add Claude hooks manually to ~/.claude/settings.json"
                fi
            fi
        else
            log_warn "~/.claude/settings.json not found"
        fi
    else
        log_info "Claude Code not installed, skipping"
    fi

    # Gemini CLI
    if command -v gemini &>/dev/null; then
        local gemini_settings="$HOME/.gemini/settings.json"
        if [ -f "$gemini_settings" ]; then
            if grep -q "aib hook" "$gemini_settings" 2>/dev/null; then
                log_warn "Gemini hooks already configured"
            else
                if command -v jq &>/dev/null; then
                    local tmp="${gemini_settings}.tmp"
                    jq '.hooks = (.hooks // {}) |
                        .hooks.SessionStart = [{"matcher": "startup", "hooks": [{"name": "map-session-start", "type": "command", "command": "aib hook start gemini"}]}] |
                        .hooks.SessionEnd = [{"matcher": "exit", "hooks": [{"name": "map-session-end", "type": "command", "command": "aib hook end gemini"}]}]' \
                        "$gemini_settings" > "$tmp" && mv "$tmp" "$gemini_settings"
                    log_ok "Gemini CLI hooks configured (SessionStart + SessionEnd)"
                else
                    log_warn "jq not found — add Gemini hooks manually to ~/.gemini/settings.json"
                fi
            fi
        else
            log_warn "~/.gemini/settings.json not found"
        fi
    else
        log_info "Gemini CLI not installed, skipping"
    fi

    # Codex CLI
    if command -v codex &>/dev/null; then
        log_warn "Codex CLI: no SessionEnd hook support — use 'aib start codex' wrapper for session tracking"
    else
        log_info "Codex CLI not installed, skipping"
    fi
}

# ============================================================
# Protocol injection
# ============================================================
PROTOCOL_MARKER="<!-- AIB:SESSION-MEMORY-PROTOCOL -->"
PROTOCOL_MARKER_END="<!-- AIB:END -->"
SKILLS_MARKER="<!-- AIB:SKILLS:START -->"
SKILLS_MARKER_END="<!-- AIB:SKILLS:END -->"

inject_protocol() {
    local target="$1"
    local protocol_file="$TEMPLATE_DIR/session-memory-protocol.md"

    for config_file in CLAUDE.md GEMINI.md AGENTS.md; do
        local fpath="$target/$config_file"

        if [ ! -f "$fpath" ]; then
            # New file: create with protocol
            { echo "$PROTOCOL_MARKER"; cat "$protocol_file"; echo "$PROTOCOL_MARKER_END"; } > "$fpath"
            log_ok "Created $config_file with protocol"
            continue
        fi

        # Normalize legacy MAP: markers
        sed -i '' 's/<!-- MAP:SESSION-MEMORY-PROTOCOL -->/<!-- AIB:SESSION-MEMORY-PROTOCOL -->/' "$fpath" 2>/dev/null || true
        sed -i '' 's/<!-- MAP:END -->/<!-- AIB:END -->/' "$fpath" 2>/dev/null || true

        # Extract user content (everything outside marker blocks and orphaned protocol)
        local user_content
        user_content=$(awk -v sm="$PROTOCOL_MARKER" -v em="$PROTOCOL_MARKER_END" '
            BEGIN { skip=0; seen_start=0; buf_len=0 }
            $0 == sm { skip=1; seen_start=1; next }
            $0 == em {
                if (!seen_start) { delete buf; buf_len=0 }
                skip=0; seen_start=0; next
            }
            !skip {
                if (!seen_start) { buf[++buf_len] = $0 }
                else {
                    for (i=1; i<=buf_len; i++) print buf[i]
                    delete buf; buf_len=0
                    print
                }
            }
            END { for (i=1; i<=buf_len; i++) print buf[i] }
        ' "$fpath" | sed '/./,$!d')

        # Rebuild: user content + protocol block
        local tmp="${fpath}.tmp"
        if [ -n "$user_content" ]; then
            echo "$user_content" > "$tmp"
            echo "" >> "$tmp"
        else
            : > "$tmp"
        fi
        echo "$PROTOCOL_MARKER" >> "$tmp"
        cat "$protocol_file" >> "$tmp"
        echo "$PROTOCOL_MARKER_END" >> "$tmp"
        mv "$tmp" "$fpath"
        log_ok "Updated protocol in $config_file"
    done
}

# Render Available Skills catalog block from skills/<n>/SKILL.md frontmatter.
# Echoes block to stdout (between markers, marker-included).
render_skills_block() {
    local target="$1"
    local skills_dir="$target/skills"

    echo "$SKILLS_MARKER"
    echo "<!-- Auto-generated by 'aib sync'. Manual edits will be overwritten. -->"
    echo "## Available Skills (this barrack)"
    echo ""

    if [ ! -d "$skills_dir" ]; then
        echo "_No skills/ directory in this barrack._"
        echo ""
        echo "$SKILLS_MARKER_END"
        return 0
    fi

    local count=0
    local rows=""
    for skill_md in "$skills_dir"/*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        local slug name desc
        slug="$(basename "$(dirname "$skill_md")")"
        name="$(skill_frontmatter_get "$skill_md" name)"
        desc="$(skill_frontmatter_get "$skill_md" description)"
        # Strip surrounding double quotes from desc if present
        desc="${desc#\"}"; desc="${desc%\"}"
        # Escape pipes for table safety
        desc="${desc//|/\\|}"
        rows+="| \`${name:-$slug}\` | ${desc:-(no description)} | \`skills/${slug}/SKILL.md\` |"$'\n'
        count=$((count + 1))
    done

    if [ "$count" -eq 0 ]; then
        echo "_No skills registered yet._ Run \`aib skills list\` to verify."
    else
        echo "Registered skills: ${count}. Read the file path's SKILL.md body before invoking."
        echo ""
        echo "| Name | Description | Source |"
        echo "|------|-------------|--------|"
        printf '%s' "$rows"
    fi
    echo ""
    echo "$SKILLS_MARKER_END"
}

# Inject (or refresh) the SKILLS_MARKER block in CLAUDE.md / GEMINI.md / AGENTS.md.
# Same extract-and-rebuild pattern as inject_protocol — preserves user content.
inject_skills_section() {
    local target="$1"
    local block
    block="$(render_skills_block "$target")"

    for config_file in CLAUDE.md GEMINI.md AGENTS.md; do
        local fpath="$target/$config_file"
        if [ ! -f "$fpath" ]; then
            log_warn "Skipping $config_file (not present — run inject_protocol first)"
            continue
        fi

        local user_content
        user_content=$(awk -v sm="$SKILLS_MARKER" -v em="$SKILLS_MARKER_END" '
            BEGIN { skip=0 }
            $0 == sm { skip=1; next }
            $0 == em { skip=0; next }
            !skip { print }
        ' "$fpath" | sed '/./,$!d')

        local tmp="${fpath}.tmp"
        if [ -n "$user_content" ]; then
            printf '%s\n\n%s\n' "$user_content" "$block" > "$tmp"
        else
            printf '%s\n' "$block" > "$tmp"
        fi
        mv "$tmp" "$fpath"
        log_ok "Refreshed Available Skills section in $config_file"
    done
}

# Maintain .claude/skills/<n> -> ../../skills/<n> relative symlinks so that
# Claude Code's project-local skill discovery picks them up automatically.
# Idempotent: replaces existing symlinks and removes orphans.
sync_claude_skills_symlinks() {
    local target="$1"
    local skills_dir="$target/skills"
    local claude_skills_dir="$target/.claude/skills"

    if [ ! -d "$skills_dir" ]; then
        # No skills — clear the .claude/skills/ directory entirely (orphan-only)
        if [ -d "$claude_skills_dir" ]; then
            find "$claude_skills_dir" -mindepth 1 -maxdepth 1 -type l -delete 2>/dev/null || true
        fi
        return 0
    fi

    mkdir -p "$claude_skills_dir"

    # 1. Create/refresh symlinks for every skill that has SKILL.md
    local linked=0
    for skill_md in "$skills_dir"/*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        local slug
        slug="$(basename "$(dirname "$skill_md")")"
        local link="$claude_skills_dir/$slug"
        # Force-replace (handles slug rename, broken link, regular dir)
        rm -rf "$link"
        ln -s "../../skills/$slug" "$link"
        linked=$((linked + 1))
    done

    # 2. Remove orphan symlinks whose source no longer exists
    if [ -d "$claude_skills_dir" ]; then
        for entry in "$claude_skills_dir"/*; do
            [ -L "$entry" ] || continue
            local slug
            slug="$(basename "$entry")"
            if [ ! -f "$skills_dir/$slug/SKILL.md" ]; then
                rm -f "$entry"
                log_info "Removed orphan symlink: .claude/skills/$slug"
            fi
        done
    fi

    [ "$linked" -gt 0 ] && log_ok "Synced $linked Claude skill symlink(s) under .claude/skills/"
    return 0
}

# Ensure .claude/skills/ is gitignored. Append if .gitignore exists and entry missing.
# Does NOT create .gitignore if absent (cmd_init's responsibility).
ensure_gitignore_skills_entry() {
    local target="$1"
    local gi="$target/.gitignore"
    [ -f "$gi" ] || return 0
    if ! grep -qx ".claude/skills/" "$gi"; then
        # Append with a comment line on first amendment
        printf '\n# aib v1.2.0: runtime symlinks materialized by `aib sync`\n.claude/skills/\n' >> "$gi"
        log_ok "Added .claude/skills/ to .gitignore"
    fi
}

# Read-only check: are the materialized W1/W2 wirings in sync with skills/?
# Echoes a single warning line per drift kind. Returns 0 (clean) or 1 (drifted).
check_skills_drift() {
    local target="$1"
    local skills_dir="$target/skills"
    local claude_skills_dir="$target/.claude/skills"
    local drifted=0

    if [ ! -d "$skills_dir" ]; then
        return 0
    fi

    # 1. W1 drift: every skill should have a symlink, every symlink a skill
    for skill_md in "$skills_dir"/*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        local slug
        slug="$(basename "$(dirname "$skill_md")")"
        if [ ! -L "$claude_skills_dir/$slug" ]; then
            log_warn "Skills drift (W1): missing .claude/skills/$slug — run 'aib sync'"
            drifted=1
        fi
    done
    if [ -d "$claude_skills_dir" ]; then
        for entry in "$claude_skills_dir"/*; do
            [ -L "$entry" ] || continue
            local slug
            slug="$(basename "$entry")"
            if [ ! -f "$skills_dir/$slug/SKILL.md" ]; then
                log_warn "Skills drift (W1): orphan .claude/skills/$slug — run 'aib sync'"
                drifted=1
            fi
        done
    fi

    # 2. W2 drift: re-render the block and diff against what's in CLAUDE.md
    # (We pick CLAUDE.md as the witness — all three are kept identical.)
    local witness="$target/CLAUDE.md"
    if [ -f "$witness" ]; then
        local expected actual
        expected="$(render_skills_block "$target")"
        actual=$(awk -v sm="$SKILLS_MARKER" -v em="$SKILLS_MARKER_END" '
            $0 == sm { capture=1 }
            capture { print }
            $0 == em { capture=0 }
        ' "$witness")
        if [ -z "$actual" ] || [ "$expected" != "$actual" ]; then
            log_warn "Skills drift (W2): CLAUDE.md SKILLS section is stale — run 'aib sync'"
            drifted=1
        fi
    fi

    return $drifted
}

# ============================================================
# aib hook start <client> — Called by CLI SessionStart hooks
# ============================================================
cmd_hook_start() {
    local client="${1:-unknown}"
    local cname
    cname=$(client_name "$client")
    local session_id
    session_id=$(make_session_id "$client")
    local started
    started="$(date '+%Y-%m-%d %H:%M')"
    local started_short
    started_short="$(date '+%m-%d %H:%M')"

    ensure_sessions_md
    ensure_sessions_dir
    cleanup_stale

    # Refresh this barrack's metadata in registry (picks up SOUL.md/wiki changes)
    local barrack_path
    barrack_path="$(pwd)"
    if [ -f "$AIB_REGISTRY" ] && jq -e --arg p "$barrack_path" '.[] | select(.path == $p)' "$AIB_REGISTRY" >/dev/null 2>&1; then
        register_barrack "$barrack_path" 2>/dev/null
    fi

    # Register in SESSIONS.md
    echo "| ${session_id} | ${cname} | ${started_short} | ${started_short} | (starting) |" >> "SESSIONS.md"
    log_info "Session registered: ${session_id}"

    # Create session context file
    local ctx_file="sessions/${session_id}.md"
    sed -e "s|{{SESSION_ID}}|${session_id}|g" \
        -e "s|{{CLIENT_NAME}}|${cname}|g" \
        -e "s|{{STARTED}}|${started}|g" \
        -e "s|{{TASK}}|(pending)|g" \
        "$TEMPLATE_DIR/session-context.md" > "$ctx_file"
    log_info "Session context: ${ctx_file}"

    # Export session ID for the CLI to use
    if [ -n "${CLAUDE_ENV_FILE:-}" ]; then
        echo "MAP_SESSION_ID=${session_id}" >> "$CLAUDE_ENV_FILE"
    fi

    # Write active session marker (LLM reads this via protocol in CLAUDE.md)
    echo "${session_id}" > "sessions/.active"

    # === LLM Context Injection (stdout → LLM) ===
    echo "[AIB SESSION] Your session file: sessions/${session_id}.md"
    echo "[AIB SESSION] You MUST update this file during work:"
    echo "  - Update **Task** field with the actual task description on first user message"
    echo "  - Append to ## Log when completing meaningful work: - [HH:MM] <request> → <result>"
    echo "  - Record key decisions in ## Decisions"
    echo "  - Record blockers in ## Blockers"
    echo ""
    echo "[AIB GROWTH] Read GROWTH.md and record knowledge AS YOU DISCOVER IT:"
    echo "  - New fact/architecture decision → wiki/topics/"
    echo "  - User correction or repeated instruction → RULES.md"
    echo "  - Before ending: audit for missed extractions (no bare '없음' — classify why)"
    echo ""

    # USER-OWNED file guidance (always shown)
    echo "[AIB FILES] Your barrack has files YOU should customize:"
    echo "  - SOUL.md: Define your agent's identity — Expertise, Personality, Core Values."
    echo "    Edit Expertise to match this barrack's domain. This shapes how the agent responds."
    echo "  - agent.yaml: Set description, models, and barrack metadata."
    echo "    A good description helps Slack routing match messages to the right barrack."
    echo "  - GROWTH.md: Customize growth triggers for this barrack's domain."
    echo "    Add domain-specific wiki topic suggestions so the agent knows what to capture."
    echo ""

    # === Violation carry-over: remediation injection (v0.9.0, OpenAI pattern) ===
    for vfile in $(ls -t sessions/*.violations 2>/dev/null | head -3); do
        local prev_sid
        prev_sid=$(basename "$vfile" .violations)
        echo "[AIB VIOLATION] Previous session ${prev_sid} had invariant violations:"
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            echo "  - ${line}"
        done < "$vfile"
        echo "[AIB REMEDIATION] Review sessions/${prev_sid}.md and address above issues if relevant."
        echo ""
        mv "$vfile" "${vfile}.delivered"
    done

    # === Blocker carry-over (v0.9.0, self-correction protocol) ===
    local latest_prev
    latest_prev=$(ls -t sessions/*.md 2>/dev/null | grep -v "${session_id}" | head -1 || true)
    if [ -n "$latest_prev" ] && [ -f "$latest_prev" ]; then
        local prev_blockers
        prev_blockers=$(sed -n '/^## Blockers/,/^## /{/^<!--/d; /^## /d; /^$/d; p}' "$latest_prev" 2>/dev/null || true)
        if [ -n "$prev_blockers" ]; then
            echo "[AIB BLOCKER] Previous session $(basename "$latest_prev" .md) has unresolved blockers:"
            echo "$prev_blockers"
            echo "[AIB] Address these if relevant to current work."
            echo ""
        fi
    fi

    # Fallback: check for empty Wiki Extractions (non-violation sessions)
    for prev_file in $(ls -t sessions/*.md 2>/dev/null | head -5); do
        [ "$prev_file" = "sessions/${session_id}.md" ] && continue
        # Skip if violation file exists/was delivered (already handled above)
        local prev_base
        prev_base=$(basename "$prev_file" .md)
        [ -f "sessions/${prev_base}.violations" ] || [ -f "sessions/${prev_base}.violations.delivered" ] && continue
        if grep -q "## Wiki Extractions" "$prev_file" && ! grep -A1 "## Wiki Extractions" "$prev_file" | grep -q "^- "; then
            local prev_status
            prev_status=$(grep "^\- \*\*Status\*\*:" "$prev_file" | sed 's/.*: //' || true)
            if [ "$prev_status" = "completed" ] || [ "$prev_status" = "interrupted" ]; then
                local prev_decisions
                prev_decisions=$( (sed -n '/^## Decisions/,/^## /{/^- /p}' "$prev_file" 2>/dev/null || true) | wc -l | tr -d ' ')
                local prev_logs
                prev_logs=$(grep -c "^- \[" "$prev_file" 2>/dev/null) || prev_logs=0
                echo "[AIB] Previous session $(basename "$prev_file" .md) has no Wiki Extractions."
                if [ "$prev_decisions" -gt 0 ] || [ "$prev_logs" -gt 1 ]; then
                    echo "[AIB] It had ${prev_logs} log entries and ${prev_decisions} decisions — review for missed knowledge."
                else
                    echo "[AIB] Review it and extract wiki-worthy knowledge if any."
                fi
                echo ""
            fi
        fi
    done

    # Output other active/recent sessions for LLM context (stdout → LLM)
    local other_sessions
    other_sessions=$(grep "^| " "SESSIONS.md" | grep -v "Session ID\|---\|${session_id}" || true)
    if [ -n "$other_sessions" ]; then
        echo "[AIB] Other active sessions:"
        echo "$other_sessions"
        echo ""
    fi

    # Output most recent interrupted/completed session for continuity
    local latest
    latest=$(ls -t sessions/*.md 2>/dev/null | grep -v "${session_id}" | head -1 || true)
    if [ -n "$latest" ] && [ -f "$latest" ]; then
        local status
        status=$(grep "^\- \*\*Status\*\*:" "$latest" | head -1 || true)
        if echo "$status" | grep -q "active\|interrupted"; then
            echo "[AIB] Recent session available for continuation:"
            echo "  File: $latest"
            head -20 "$latest"
            echo "..."
            echo ""
            echo "To continue this session, the LLM should read sessions/$(basename "$latest") and update its own session file."
        fi
    fi
}

# ============================================================
# aib hook end <client> — Called by CLI SessionEnd hooks
# ============================================================
cmd_hook_end() {
    local client="${1:-unknown}"

    # Find this client's active session in SESSIONS.md
    local session_id
    session_id=$(grep "^| ${client}-" "SESSIONS.md" 2>/dev/null | tail -1 | awk -F'|' '{print $2}' | tr -d ' ' || true)

    if [ -z "$session_id" ]; then
        log_warn "No active session found for ${client}"
        return
    fi

    # Remove from SESSIONS.md
    local tmp="SESSIONS.md.tmp"
    grep -v "^| ${session_id} " "SESSIONS.md" > "$tmp" 2>/dev/null || true
    mv "$tmp" "SESSIONS.md"
    rm -f "sessions/.active"
    log_info "Session unregistered: ${session_id}"

    # Update session file status
    local ctx_file="sessions/${session_id}.md"
    if [ -f "$ctx_file" ]; then
        sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: completed/' "$ctx_file" 2>/dev/null || true
        sed -i '' "s/^- \*\*Ended\*\*: (active)/- **Ended**: $(date '+%Y-%m-%d %H:%M')/" "$ctx_file" 2>/dev/null || true
        log_info "Session marked completed: ${ctx_file}"

        # Growth validation: warn if meaningful work but no growth updates
        local log_count
        log_count=$(grep -c "^- \[" "$ctx_file" 2>/dev/null) || log_count=0
        local decision_count
        decision_count=$( (sed -n '/^## Decisions/,/^## /{/^- /p}' "$ctx_file" 2>/dev/null || true) | wc -l | tr -d ' ')
        local has_growth=false
        if (sed -n '/^## Wiki Extractions/,/^## /{/^- /p}' "$ctx_file" 2>/dev/null || true) | grep -q . 2>/dev/null; then
            has_growth=true
        fi
        if [ "$log_count" -ge 2 ] || [ "$decision_count" -ge 1 ]; then
            if ! $has_growth; then
                log_warn "Session ${session_id} had ${log_count} log entries and ${decision_count} decisions but NO growth updates."
                log_warn "Review: sessions/${session_id}.md"
            fi
        fi

        # === Invariant Violation Recording (v0.9.0) ===
        # Record violations to file; next SessionStart injects them as remediation instructions
        local violations=""

        # Check: Task still "(pending)"
        local task_field
        task_field=$(grep "^\- \*\*Task\*\*:" "$ctx_file" | sed 's/.*: //' || true)
        if [ "$task_field" = "(pending)" ]; then
            # Empty session (no task + no log) → auto-delete
            if [ "$log_count" -eq 0 ]; then
                rm -f "$ctx_file" "sessions/${session_id}.violations"
                log_info "Empty session deleted: ${session_id} (no task, no log)"
                return
            fi
            violations="${violations}TASK_PENDING: Task 필드가 업데이트되지 않음. 첫 사용자 메시지 후 반드시 Task를 설정하세요.\n"
        fi

        # Check: Wiki Extractions — also accept "(없음" classification as valid
        local has_classification=false
        if (sed -n '/^## Wiki Extractions/,/^## /{/^(없음/p}' "$ctx_file" 2>/dev/null || true) | grep -q "(없음" 2>/dev/null; then
            has_classification=true
        fi
        if [ "$log_count" -ge 2 ] || [ "$decision_count" -ge 1 ]; then
            if ! $has_growth && ! $has_classification; then
                violations="${violations}GROWTH_MISSING: ${log_count} log + ${decision_count} decisions이나 Wiki Extractions가 비어있음. 분류별 사유라도 기술하세요.\n"
            fi
        fi

        # Check: Unresolved blockers (carry-over to next session)
        local blocker_content
        blocker_content=$(sed -n '/^## Blockers/,/^## /{/^<!--/d; /^## /d; /^$/d; p}' "$ctx_file" 2>/dev/null || true)
        if [ -n "$blocker_content" ]; then
            violations="${violations}UNRESOLVED_BLOCKERS: 해소되지 않은 블로커 존재. 다음 세션에서 확인하세요.\n"
        fi

        # Write violations file if any
        if [ -n "$violations" ]; then
            local vfile="sessions/${session_id}.violations"
            printf '%b' "$violations" > "$vfile"
            log_warn "Session ${session_id}: violations recorded → ${vfile}"
        fi

        # Summarize from transcript (Claude) or raw capture (Gemini/Codex)
        local raw_file=""
        if [ "$client" = "claude" ] && [ -n "${CLAUDE_TRANSCRIPT_PATH:-}" ] && [ -f "${CLAUDE_TRANSCRIPT_PATH}" ]; then
            raw_file="${CLAUDE_TRANSCRIPT_PATH}"
            log_info "Using Claude transcript: ${raw_file}"
        elif [ -f "sessions/${session_id}.raw" ]; then
            raw_file="sessions/${session_id}.raw"
            log_info "Using raw capture: ${raw_file}"
        fi

        if [ -n "$raw_file" ] && [ -s "$raw_file" ]; then
            summarize_session "$session_id" "$ctx_file" "$raw_file"
        else
            # No raw data — just append basic summary
            local log_count
            log_count=$(grep -c "^- \[" "$ctx_file" 2>/dev/null) || log_count=0
            {
                echo ""
                echo "## Summary (auto-generated)"
                echo "- Log entries: ${log_count}"
                echo "- Duration: $(grep '^\- \*\*Started\*\*:' "$ctx_file" | sed 's/.*: //') ~ $(date '+%Y-%m-%d %H:%M')"
                echo "- Note: no raw capture available for LLM summarization"
            } >> "$ctx_file"
        fi
    fi
}

# ============================================================
# aib hook continue <session_id> — Continue another session
# ============================================================
cmd_hook_continue() {
    local target_id="${1:-}"

    if [ -z "$target_id" ]; then
        log_err "Usage: aib hook continue <session_id>"
        # List available sessions
        echo "Available sessions:" >&2
        ls -t sessions/*.md 2>/dev/null | while read -r f; do
            local name status
            name=$(basename "$f" .md)
            status=$(grep "^\- \*\*Status\*\*:" "$f" | sed 's/.*: //' || echo "unknown")
            echo "  $name ($status)" >&2
        done
        exit 1
    fi

    local ctx_file="sessions/${target_id}.md"
    if [ ! -f "$ctx_file" ]; then
        log_err "Session file not found: ${ctx_file}"
        exit 1
    fi

    # Output full session context (stdout → LLM)
    echo "[AIB] Continuing session: ${target_id}"
    echo ""
    cat "$ctx_file"
    echo ""
    echo "[AIB] Please continue the work described above. Update your session file with new progress."
}

# ============================================================
# aib start <client> [task] — User-facing wrapper
# ============================================================
cmd_start() {
    local client=""
    local task=""
    local skip_permissions=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-permissions) skip_permissions=true; shift ;;
            -*)  log_err "Unknown option: $1"; exit 1 ;;
            *)
                if [ -z "$client" ]; then
                    client="$1"
                elif [ -z "$task" ]; then
                    task="$1"
                fi
                shift ;;
        esac
    done

    if [ -z "$client" ]; then
        log_err "Usage: aib start <claude|gemini|codex> [task] [--skip-permissions]"
        exit 1
    fi

    local cname
    cname=$(client_name "$client")
    local session_id
    session_id=$(make_session_id "$client")
    local started
    started="$(date '+%Y-%m-%d %H:%M')"
    local started_short
    started_short="$(date '+%m-%d %H:%M')"
    local task_desc="${task:-진행 중}"

    ensure_sessions_md
    ensure_sessions_dir

    # Register
    echo "| ${session_id} | ${cname} | ${started_short} | ${started_short} | ${task_desc} |" >> "SESSIONS.md"

    # Create session context file
    local ctx_file="sessions/${session_id}.md"
    sed -e "s|{{SESSION_ID}}|${session_id}|g" \
        -e "s|{{CLIENT_NAME}}|${cname}|g" \
        -e "s|{{STARTED}}|${started}|g" \
        -e "s|{{TASK}}|${task_desc}|g" \
        "$TEMPLATE_DIR/session-context.md" > "$ctx_file"

    local raw_file="sessions/${session_id}.raw"

    log_info "Session registered: ${session_id} — ${task_desc}"
    log_info "Context file: ${ctx_file}"
    log_info "Raw capture: ${raw_file}"

    # Trap for cleanup + summarization
    cleanup() {
        # 1. Unregister from SESSIONS.md
        if [ -f "SESSIONS.md" ]; then
            local tmp="SESSIONS.md.tmp"
            grep -v "^| ${session_id} " "SESSIONS.md" > "$tmp" 2>/dev/null || true
            mv "$tmp" "SESSIONS.md"
        fi
        rm -f "sessions/.active"

        # 2. Mark completed
        if [ -f "$ctx_file" ]; then
            sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: completed/' "$ctx_file" 2>/dev/null || true
            sed -i '' "s/^- \*\*Ended\*\*: (active)/- **Ended**: $(date '+%Y-%m-%d %H:%M')/" "$ctx_file" 2>/dev/null || true
        fi

        # 3. Summarize raw capture with LLM
        if [ -f "$raw_file" ] && [ -s "$raw_file" ]; then
            log_info "Summarizing session with LLM..."
            summarize_session "$session_id" "$ctx_file" "$raw_file"
        fi

        log_info "Session unregistered: ${session_id}"
    }
    trap cleanup EXIT

    # Write active session marker
    echo "${session_id}" > "sessions/.active"

    # Build permission-skip flags per client
    local skip_flags=""
    if $skip_permissions; then
        case "$client" in
            claude) skip_flags="--dangerously-skip-permissions" ;;
            gemini) skip_flags="--yolo" ;;
            codex)  skip_flags="--dangerously-bypass-approvals-and-sandbox" ;;
            *)      log_warn "Unknown client '$client': --skip-permissions ignored" ;;
        esac
        [ -n "$skip_flags" ] && log_warn "Permission skip enabled: $skip_flags"
    fi

    # v1.2.0: non-blocking drift warning (does not block launch)
    check_skills_drift "$(pwd)" || true

    # Launch CLI with script capture (Gemini/Codex)
    # Claude uses $CLAUDE_TRANSCRIPT_PATH instead (handled in hook end)
    if [ "$client" = "claude" ]; then
        validate_claude_settings
        exec "$client" $skip_flags
    else
        if [ -n "$skip_flags" ]; then
            script -q "$raw_file" "$client" $skip_flags
        else
            script -q "$raw_file" "$client"
        fi
    fi
}

# ============================================================
# aib status
# ============================================================
cmd_status() {
    echo -e "${CYAN}AI Barracks Status${NC}" >&2
    echo "" >&2

    # Sessions
    if [ -f "SESSIONS.md" ]; then
        local count
        count=$(grep -c "^| [a-z]" SESSIONS.md 2>/dev/null || echo "0")
        echo -e "Sessions: ${GREEN}${count} active${NC}" >&2
        if [ "$count" -gt 0 ]; then
            grep "^| [a-z]" SESSIONS.md >&2
        fi
    else
        echo -e "Sessions: ${YELLOW}SESSIONS.md not found${NC}" >&2
    fi

    # Session files
    if [ -d "sessions" ]; then
        local total active completed interrupted
        total=$(find sessions -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        active=$(grep -rl "Status.*active" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        completed=$(grep -rl "Status.*completed" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        interrupted=$(grep -rl "Status.*interrupted" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        echo -e "Session files: ${total} total (${GREEN}${active} active${NC}, ${completed} completed, ${YELLOW}${interrupted} interrupted${NC})" >&2
    fi

    echo "" >&2

    # Wiki
    if [ -d "wiki/topics" ]; then
        local topics
        topics=$(find wiki/topics -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "Wiki: ${GREEN}${topics} topics${NC}" >&2
        if [ -f "wiki/Index.md" ]; then
            grep "^|" wiki/Index.md | grep -v "Topic\|---" 2>/dev/null >&2 || true
        fi
    else
        echo -e "Wiki: ${YELLOW}not initialized${NC}" >&2
    fi
}

# ============================================================
# aib wiki lint [--fix] — Check wiki health and freshness (v0.9.0)
# ============================================================
cmd_wiki_lint() {
    local fix=false
    [ "${1:-}" = "--fix" ] && fix=true
    local issues=0
    local now_epoch
    now_epoch=$(date +%s)
    local six_months=$((180 * 86400))

    echo -e "${CYAN}Wiki Lint Report${NC}" >&2
    echo "" >&2

    # 1. Staleness: [YYYY-MM-DD] tags older than 6 months
    if [ -d "wiki/topics" ]; then
        for f in wiki/topics/*.md; do
            [ ! -f "$f" ] && continue
            while IFS= read -r line; do
                if [[ "$line" =~ \[([0-9]{4}-[0-9]{2}-[0-9]{2})\] ]] && ! echo "$line" | grep -q "\[STALE?\]"; then
                    local ds="${BASH_REMATCH[1]}"
                    local ep
                    ep=$(date -j -f "%Y-%m-%d" "$ds" +%s 2>/dev/null || echo "0")
                    if [ "$ep" -gt 0 ] && [ $((now_epoch - ep)) -gt "$six_months" ]; then
                        echo -e "  ${YELLOW}[STALE]${NC} ${f}: ${ds} — $(echo "$line" | head -c 80)" >&2
                        issues=$((issues + 1))
                        if $fix; then
                            sed -i '' "s/\[${ds}\]/[${ds}] [STALE?]/" "$f"
                        fi
                    fi
                fi
            done < "$f"

            # Oversized topic check (200 line limit)
            local lc
            lc=$(wc -l < "$f" | tr -d ' ')
            if [ "$lc" -gt 200 ]; then
                echo -e "  ${YELLOW}[OVERSIZED]${NC} ${f}: ${lc} lines (limit: 200)" >&2
                issues=$((issues + 1))
            fi
        done
    fi

    # 2. Index.md vs topics/ directory mismatch
    if [ -f "wiki/Index.md" ] && [ -d "wiki/topics" ]; then
        # Files referenced in Index but missing on disk
        grep -o "topics/[^)]*\.md" wiki/Index.md 2>/dev/null | sort -u | while read -r ref; do
            if [ ! -f "wiki/${ref}" ]; then
                echo -e "  ${RED}[MISSING]${NC} Index.md → ${ref} (file not found)" >&2
                issues=$((issues + 1))
            fi
        done

        # Files on disk but not in Index
        for f in wiki/topics/*.md; do
            [ ! -f "$f" ] && continue
            local fn
            fn=$(basename "$f")
            if ! grep -q "$fn" wiki/Index.md 2>/dev/null; then
                echo -e "  ${YELLOW}[UNINDEXED]${NC} ${f} (not in Index.md)" >&2
                issues=$((issues + 1))
            fi
        done
    fi

    # 3. RULES.md duplicate rules
    if [ -f "RULES.md" ]; then
        local dupes
        dupes=$(grep "^- \[" RULES.md 2>/dev/null | sed 's/^- \[[0-9-]*\] //' | sort | uniq -d || true)
        if [ -n "$dupes" ]; then
            echo -e "  ${YELLOW}[DUPLICATE]${NC} RULES.md has duplicate rules:" >&2
            echo "$dupes" | while read -r d; do echo "    - $d" >&2; done
            issues=$((issues + 1))
        fi
    fi

    echo "" >&2
    if [ "$issues" -eq 0 ]; then
        log_ok "Wiki lint: no issues found"
    else
        log_warn "Wiki lint: ${issues} issue(s) found"
        if ! $fix; then
            echo "  Run 'aib wiki lint --fix' to auto-fix staleness markers." >&2
        fi
    fi
}

# ============================================================
# aib council [flags] "topic" — Wrapper around council.sh
# ============================================================
cmd_council() {
    if [ $# -eq 0 ]; then
        log_err "Usage: aib council [-r rounds] [-m mode] \"topic\""
        echo "  -r N       Number of debate rounds (default: 2)" >&2
        echo "  -m MODE    Mode: debate|adversarial|pipeline (default: debate)" >&2
        echo "" >&2
        echo "Examples:" >&2
        echo "  aib council \"REST vs gRPC\"" >&2
        echo "  aib council -m adversarial -r 3 \"Kafka vs Pulsar\"" >&2
        exit 1
    fi

    # Locate council.sh (priority: env > workspace-local > brew-installed > fallback)
    local council_script=""
    local script_dir
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    if [ -n "${AIB_COUNCIL_SCRIPT:-}" ] && [ -x "$AIB_COUNCIL_SCRIPT" ]; then
        council_script="$AIB_COUNCIL_SCRIPT"
    elif [ -x "./scripts/council.sh" ]; then
        council_script="./scripts/council.sh"
    elif [ -x "${script_dir}/../scripts/council.sh" ]; then
        council_script="${script_dir}/../scripts/council.sh"
    elif [ -x "${script_dir}/../share/ai-barracks/scripts/council.sh" ]; then
        council_script="${script_dir}/../share/ai-barracks/scripts/council.sh"
    fi

    if [ -z "$council_script" ]; then
        log_err "council.sh not found."
        echo "  Reinstall: brew reinstall ai-barracks" >&2
        exit 1
    fi

    exec "$council_script" "$@"
}

# ============================================================
# aib barracks [list|remove|route|refresh] — Manage registered barracks
# ============================================================
cmd_barracks() {
    ensure_registry
    local subcmd="${1:-list}"

    case "$subcmd" in
        list)
            echo -e "${CYAN}Registered Barracks${NC}" >&2
            echo "" >&2
            if [ "$(jq length "$AIB_REGISTRY")" -eq 0 ]; then
                echo "  (none — run 'aib init' in a directory to register)" >&2
                return
            fi
            jq -r '.[] | "  \(.name)\n    Path: \(.path)\n    Expertise: \(.expertise)\n    Topics: \(.topics)\n"' "$AIB_REGISTRY" >&2
            ;;
        remove)
            local path="${2:-}"
            if [ -z "$path" ]; then
                log_err "Usage: aib barracks remove <path>"
                exit 1
            fi
            path="$(cd "$path" 2>/dev/null && pwd || echo "$path")"
            unregister_barrack "$path"
            ;;
        route)
            local query="${2:-}"
            if [ -z "$query" ]; then
                log_err "Usage: aib barracks route \"query text\""
                exit 1
            fi
            route_to_barrack "$query"
            ;;
        refresh)
            # Re-scan all registered barracks and update metadata
            local paths
            paths=$(jq -r '.[].path' "$AIB_REGISTRY")
            for p in $paths; do
                if [ -d "$p" ]; then
                    register_barrack "$p"
                else
                    log_warn "Barrack not found, removing: $p"
                    unregister_barrack "$p"
                fi
            done
            log_ok "All barracks refreshed"
            ;;
        *)
            log_err "Usage: aib barracks <list|remove|route|refresh>"
            exit 1
            ;;
    esac
}

route_to_barrack() {
    local query="$1"
    local query_lower
    query_lower=$(echo "$query" | tr '[:upper:]' '[:lower:]')

    ensure_registry
    local best_path=""
    local best_score=0

    # Score each barrack by keyword match
    while IFS= read -r entry; do
        local path name expertise topics
        path=$(echo "$entry" | jq -r '.path')
        name=$(echo "$entry" | jq -r '.name')
        expertise=$(echo "$entry" | jq -r '.expertise' | tr '[:upper:]' '[:lower:]')
        topics=$(echo "$entry" | jq -r '.topics' | tr '[:upper:]' '[:lower:]')

        local score=0
        local all_keywords="${expertise},${topics},${name}"

        # Count keyword matches
        IFS=',' read -ra keywords <<< "$all_keywords"
        for kw in "${keywords[@]}"; do
            kw=$(echo "$kw" | tr -d ' ')
            [ -z "$kw" ] && continue
            if echo "$query_lower" | grep -qi "$kw" 2>/dev/null; then
                score=$((score + 1))
            fi
        done

        if [ "$score" -gt "$best_score" ]; then
            best_score=$score
            best_path=$path
        fi
    done < <(jq -c '.[]' "$AIB_REGISTRY")

    if [ -n "$best_path" ] && [ "$best_score" -gt 0 ]; then
        echo "$best_path"
    else
        # Return default (first registered barrack)
        jq -r '.[0].path // empty' "$AIB_REGISTRY"
    fi
}

# ============================================================
# aib sync [--dry-run] [path]
# ============================================================

# Sync: create missing scaffold files from templates
sync_new_files() {
    local target="$1" dry_run="$2"
    local manifest="$TEMPLATE_DIR/.sync-manifest"
    local ws_name
    ws_name=$(basename "$target")

    # Collect scaffold and system files from manifest
    while IFS=: read -r file strategy; do
        [[ "$file" =~ ^#.*$ || -z "$file" ]] && continue

        local dest="$target/$file"

        # system strategy: always overwrite from template (system-owned docs)
        if [ "$strategy" = "system" ]; then
            if $dry_run; then
                if [ -f "$dest" ]; then
                    log_info "[dry-run] Would update: $file (system template)"
                else
                    log_info "[dry-run] Would create: $file (system template)"
                fi
            else
                mkdir -p "$(dirname "$dest")"
                sed "s|{{WORKSPACE_NAME}}|${ws_name}|g; s|{{AIB_VERSION}}|${AIB_VERSION}|g" \
                    "$TEMPLATE_DIR/$file" > "$dest"
                log_ok "Synced: $file (system)"
            fi
            continue
        fi

        # scaffold strategy: create if missing
        [ "$strategy" != "scaffold" ] && continue

        if [ ! -f "$dest" ]; then
            if $dry_run; then
                log_info "[dry-run] Would create: $file (from template)"
            else
                mkdir -p "$(dirname "$dest")"
                sed "s|{{WORKSPACE_NAME}}|${ws_name}|g; s|{{AIB_VERSION}}|${AIB_VERSION}|g" \
                    "$TEMPLATE_DIR/$file" > "$dest"
                log_ok "Created: $file"
            fi
        else
            log_info "Skip: $file (already exists)"
        fi
    done < "$manifest"

    # Also check for template files NOT in manifest — default to scaffold
    while IFS= read -r tpl_file; do
        local rel="${tpl_file#$TEMPLATE_DIR/}"
        [[ "$rel" == .sync-manifest ]] && continue
        grep -q "^${rel}:" "$manifest" 2>/dev/null && continue

        local dest="$target/$rel"
        if [ ! -f "$dest" ]; then
            if $dry_run; then
                log_info "[dry-run] Would create: $rel (new template, not in manifest)"
            else
                mkdir -p "$(dirname "$dest")"
                sed "s|{{WORKSPACE_NAME}}|${ws_name}|g; s|{{AIB_VERSION}}|${AIB_VERSION}|g" \
                    "$TEMPLATE_DIR/$rel" > "$dest"
                log_ok "Created: $rel (new template)"
            fi
        fi
    done < <(find "$TEMPLATE_DIR" -type f -not -name '.sync-manifest')
}

# Sync: ensure H2 sections from template exist in barrack file
sync_sections_md() {
    local target="$1" dry_run="$2"
    local manifest="$TEMPLATE_DIR/.sync-manifest"

    while IFS=: read -r file strategy; do
        [[ "$file" =~ ^#.*$ || -z "$file" ]] && continue
        [ "$strategy" != "sections" ] && continue

        local dest="$target/$file"
        local tpl="$TEMPLATE_DIR/$file"

        if [ ! -f "$dest" ]; then
            log_warn "$file: not found, skipping section sync"
            continue
        fi

        # For SOUL.md: check for AIB markers
        if [ "$file" = "SOUL.md" ] && ! grep -q "AIB:SOUL" "$dest"; then
            log_warn "$file: no AIB markers found, skipping section sync"
            continue
        fi

        # Extract H2 headings from template and barrack
        local missing_sections=""
        while IFS= read -r heading; do
            if ! grep -qF "$heading" "$dest"; then
                missing_sections="${missing_sections}${heading}\n"
            fi
        done < <(grep "^## " "$tpl")

        if [ -z "$missing_sections" ]; then
            log_info "Skip: $file (all sections present)"
            continue
        fi

        if $dry_run; then
            echo -e "$missing_sections" | while IFS= read -r h; do
                [ -z "$h" ] && continue
                log_info "[dry-run] Would add to $file: $h"
            done
            continue
        fi

        # Insert missing sections
        if [ "$file" = "SOUL.md" ] && grep -q "AIB:SOUL:END" "$dest"; then
            # Insert before <!-- AIB:SOUL:END -->
            local tmp="${dest}.tmp"
            local insert=""
            while IFS= read -r h; do
                [ -z "$h" ] && continue
                insert="${insert}\n${h}\n"
            done < <(echo -e "$missing_sections")
            sed "/<!-- AIB:SOUL:END -->/i\\
${insert}" "$dest" > "$tmp"
            mv "$tmp" "$dest"
        else
            # Append at EOF
            echo -e "$missing_sections" | while IFS= read -r h; do
                [ -z "$h" ] && continue
                echo "" >> "$dest"
                echo "$h" >> "$dest"
            done
        fi
        log_ok "Updated: $file (added missing sections)"
    done < "$manifest"
}

# Sync: merge missing top-level YAML keys into agent.yaml
sync_yaml_fields() {
    local target="$1" dry_run="$2"
    local dest="$target/agent.yaml"
    local tpl="$TEMPLATE_DIR/agent.yaml"

    if [ ! -f "$dest" ]; then
        log_warn "agent.yaml: not found, skipping field merge"
        return
    fi

    local added=false
    while IFS= read -r line; do
        # Match top-level keys (no leading whitespace, has colon)
        if [[ "$line" =~ ^([a-z_]+): ]]; then
            local key="${BASH_REMATCH[1]}"
            if ! grep -q "^${key}:" "$dest"; then
                if $dry_run; then
                    log_info "[dry-run] Would add to agent.yaml: $key"
                else
                    echo "" >> "$dest"
                    echo "$line" >> "$dest"
                    # Append indented children if any
                    local in_block=false
                    while IFS= read -r child; do
                        if [[ "$child" =~ ^[[:space:]] ]]; then
                            echo "$child" >> "$dest"
                        else
                            break
                        fi
                    done
                    added=true
                fi
            fi
        fi
    done < "$tpl"

    if $added; then
        log_ok "Updated: agent.yaml (added missing fields)"
    else
        if ! $dry_run; then
            log_info "Skip: agent.yaml (all fields present)"
        fi
    fi
}

# Sync: stamp aib_version in agent.yaml
sync_version_stamp() {
    local target="$1" dry_run="$2"
    local dest="$target/agent.yaml"

    if [ ! -f "$dest" ]; then
        return
    fi

    if grep -q "^aib_version:" "$dest"; then
        local current
        current=$(grep "^aib_version:" "$dest" | sed 's/^aib_version: *//')
        if [ "$current" = "$AIB_VERSION" ]; then
            log_info "Skip: aib_version already $AIB_VERSION"
            return
        fi
        if $dry_run; then
            log_info "[dry-run] Would update aib_version: $current → $AIB_VERSION"
        else
            sed -i '' "s/^aib_version: .*/aib_version: ${AIB_VERSION}/" "$dest"
            log_ok "Updated: aib_version $current → $AIB_VERSION"
        fi
    else
        if $dry_run; then
            log_info "[dry-run] Would add aib_version: $AIB_VERSION to agent.yaml"
        else
            echo "" >> "$dest"
            echo "aib_version: ${AIB_VERSION}" >> "$dest"
            log_ok "Added: aib_version ${AIB_VERSION}"
        fi
    fi
}

cmd_sync() {
    local dry_run=false
    local target=""

    # Parse flags
    while [[ "${1:-}" == --* ]]; do
        case "$1" in
            --dry-run) dry_run=true; shift ;;
            *) log_err "Unknown flag: $1"; exit 1 ;;
        esac
    done
    target="${1:-.}"
    target="$(cd "$target" && pwd)"

    # Verify this is a barrack
    if [ ! -f "$target/agent.yaml" ]; then
        log_err "Not a barrack directory (no agent.yaml): $target"
        exit 1
    fi

    local mode=""
    $dry_run && mode=" (dry-run)"
    log_info "Syncing barrack: $(basename "$target")${mode} — aib v${AIB_VERSION}"

    # 1. Protocol injection (existing)
    if $dry_run; then
        log_info "[dry-run] Would update protocol/skills section + .claude/skills/ symlinks"
    else
        inject_protocol "$target"
        inject_skills_section "$target"
        sync_claude_skills_symlinks "$target"
        ensure_gitignore_skills_entry "$target"
    fi

    # 2. Scaffold missing files
    sync_new_files "$target" "$dry_run"

    # 3. Section guards (SOUL.md, RULES.md)
    sync_sections_md "$target" "$dry_run"

    # 4. YAML field merge (agent.yaml)
    sync_yaml_fields "$target" "$dry_run"

    # 5. Version stamp
    sync_version_stamp "$target" "$dry_run"

    # 6. Update registry metadata
    if ! $dry_run; then
        register_barrack "$target"
    fi

    log_ok "Sync complete${mode}"
}

# ============================================================
# aib sessions clean — Remove empty (pending + no log) session files
# ============================================================
cmd_sessions_clean() {
    local dry_run=false
    [ "${1:-}" = "--dry-run" ] && dry_run=true

    local count=0
    for ctx_file in sessions/*.md; do
        [ -f "$ctx_file" ] || continue
        [ "$(basename "$ctx_file")" = ".active" ] && continue

        local task_field log_count status_field
        task_field=$(grep "^\- \*\*Task\*\*:" "$ctx_file" | sed 's/.*: //' || true)
        log_count=$(grep -c "^- \[" "$ctx_file" 2>/dev/null) || log_count=0
        status_field=$(grep "^\- \*\*Status\*\*:" "$ctx_file" | sed 's/.*: //' || true)

        # Skip active sessions
        [ "$status_field" = "active" ] && continue

        if [ "$task_field" = "(pending)" ] && [ "$log_count" -eq 0 ]; then
            local session_id
            session_id=$(basename "$ctx_file" .md)
            if $dry_run; then
                log_info "[dry-run] Would delete: ${ctx_file}"
            else
                rm -f "$ctx_file" "sessions/${session_id}.violations" "sessions/${session_id}.violations.delivered"
                log_ok "Deleted empty session: ${session_id}"
            fi
            count=$((count + 1))
        fi
    done

    if [ "$count" -eq 0 ]; then
        log_info "No empty sessions found"
    elif $dry_run; then
        log_info "Would clean ${count} empty session(s) — run without --dry-run to apply"
    else
        log_ok "Cleaned ${count} empty session(s)"
    fi
}

# ============================================================
# aib skills <list|doctor> [path]   (v1.1.0)
# ============================================================

# Extract a SKILL.md frontmatter field. Frontmatter = first --- ... --- block.
# Args: $1 = file, $2 = field name. Echoes value (may be empty).
skill_frontmatter_get() {
    local file="$1" field="$2"
    awk -v f="$field" '
        /^---[[:space:]]*$/ { fm++; if (fm == 2) exit; next }
        fm == 1 {
            if (match($0, "^[[:space:]]*" f "[[:space:]]*:")) {
                v = substr($0, RSTART + RLENGTH)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                gsub(/^"|"$/, "", v)
                print v
                exit
            }
        }
    ' "$file"
}

cmd_skills_list() {
    local target="${1:-.}"
    target="$(cd "$target" && pwd)"
    if [ ! -f "$target/agent.yaml" ]; then
        log_err "Not a barrack directory (no agent.yaml): $target"
        exit 1
    fi
    local skills_dir="$target/skills"
    if [ ! -d "$skills_dir" ]; then
        log_info "No skills/ directory in $target"
        return 0
    fi
    local count=0
    printf "${CYAN}%-20s${NC}  %s\n" "SLUG" "DESCRIPTION" >&2
    printf "${CYAN}%-20s${NC}  %s\n" "--------------------" "-------------------------------" >&2
    for skill_md in "$skills_dir"/*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        local slug name desc
        slug="$(basename "$(dirname "$skill_md")")"
        name="$(skill_frontmatter_get "$skill_md" name)"
        desc="$(skill_frontmatter_get "$skill_md" description)"
        # Truncate long descriptions for the list view
        if [ "${#desc}" -gt 70 ]; then
            desc="${desc:0:67}..."
        fi
        printf "%-20s  %s\n" "${name:-$slug}" "$desc"
        count=$((count + 1))
    done
    log_info "${count} skill(s) discovered"
}

cmd_skills_doctor() {
    local target="${1:-.}"
    target="$(cd "$target" && pwd)"
    if [ ! -f "$target/agent.yaml" ]; then
        log_err "Not a barrack directory (no agent.yaml): $target"
        exit 1
    fi
    local skills_dir="$target/skills"
    if [ ! -d "$skills_dir" ]; then
        log_info "No skills/ directory in $target — nothing to check"
        return 0
    fi
    local issues=0
    for skill_md in "$skills_dir"/*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        local slug name desc
        slug="$(basename "$(dirname "$skill_md")")"
        name="$(skill_frontmatter_get "$skill_md" name)"
        desc="$(skill_frontmatter_get "$skill_md" description)"
        local rel_path
        rel_path="${skill_md#$target/}"
        if [ -z "$name" ]; then
            log_err "$rel_path: missing 'name' in frontmatter"
            issues=$((issues + 1))
        elif [ "$name" != "$slug" ]; then
            log_err "$rel_path: name='$name' does not match directory slug '$slug'"
            issues=$((issues + 1))
        fi
        if [ -z "$desc" ]; then
            log_err "$rel_path: missing 'description' in frontmatter (this is the discovery trigger)"
            issues=$((issues + 1))
        fi
    done
    # Detect orphan directories without SKILL.md
    for d in "$skills_dir"/*/; do
        [ -d "$d" ] || continue
        if [ ! -f "$d/SKILL.md" ]; then
            log_warn "${d#$target/}: directory exists but no SKILL.md"
            issues=$((issues + 1))
        fi
    done
    if [ "$issues" -eq 0 ]; then
        # v1.2.0: also verify W1+W2 are in sync with the catalog
        if ! check_skills_drift "$target"; then
            return 1
        fi
        log_ok "All skills look healthy"
    else
        log_err "Found $issues issue(s) — fix above"
        exit 1
    fi
}

# v1.2.0: read-only drift check (used by cmd_start as a non-blocking warning)
cmd_skills_check() {
    local target="${1:-.}"
    target="$(cd "$target" && pwd)"
    [ -f "$target/agent.yaml" ] || { log_err "Not a barrack: $target"; exit 1; }
    if check_skills_drift "$target"; then
        log_ok "Skills wiring is in sync"
    else
        return 1
    fi
}

# ============================================================
# Main
# ============================================================
case "${1:-}" in
    init)    shift; cmd_init "$@" ;;
    start)   shift; cmd_start "$@" ;;
    hook)
        shift
        case "${1:-}" in
            start)    shift; cmd_hook_start "$@" ;;
            end)      shift; cmd_hook_end "$@" ;;
            continue) shift; cmd_hook_continue "$@" ;;
            *)        log_err "Usage: aib hook <start|end|continue> [args]"; exit 1 ;;
        esac
        ;;
    status)  cmd_status ;;
    sync)    shift; cmd_sync "$@" ;;
    council) shift; cmd_council "$@" ;;
    barracks) shift; cmd_barracks "$@" ;;
    sessions)
        shift
        case "${1:-}" in
            clean) shift; cmd_sessions_clean "$@" ;;
            *)     log_err "Usage: aib sessions <clean> [--dry-run]"; exit 1 ;;
        esac
        ;;
    wiki)
        shift
        case "${1:-}" in
            lint) shift; cmd_wiki_lint "$@" ;;
            *)    log_err "Usage: aib wiki <lint> [--fix]"; exit 1 ;;
        esac
        ;;
    skills)
        shift
        case "${1:-}" in
            list)   shift; cmd_skills_list "$@" ;;
            doctor) shift; cmd_skills_doctor "$@" ;;
            check)  shift; cmd_skills_check "$@" ;;
            *)      log_err "Usage: aib skills <list|doctor|check> [path]"; exit 1 ;;
        esac
        ;;
    version) echo "aib v${AIB_VERSION}" ;;
    -h|--help|help|"")
        echo "aib — AI Barracks CLI v${AIB_VERSION}"
        echo ""
        echo "Commands:"
        echo "  init [path]                    Initialize barrack + configure hooks"
        echo "  start <client> [task] [--skip-permissions]  Start LLM session with tracking"
        echo "  hook start <client>            (Auto) Called by CLI SessionStart hooks"
        echo "  hook end <client>              (Auto) Called by CLI SessionEnd hooks"
        echo "  hook continue <session_id>     Continue another CLI's session"
        echo "  barracks [list|remove|route|refresh]   Manage registered barracks"
        echo "  status                         Show active sessions and wiki"
        echo "  sessions clean [--dry-run]     Remove empty (no task + no log) sessions"
        echo "  wiki lint [--fix]              Check wiki health and freshness"
        echo "  skills list [path]             List skills with name + description"
        echo "  skills doctor [path]           Validate SKILL.md frontmatter"
        echo "  skills check [path]            Detect W1/W2 drift (used by 'aib start')"
        echo "  sync [--dry-run] [path]        Sync templates + protocol to barrack"
        echo "  council [-r N] [-m MODE] \"topic\"  Run multi-LLM debate council"
        echo "  version                        Show version"
        ;;
    *)
        log_err "Unknown command: $1"
        echo "Run 'aib --help' for usage"
        exit 1
        ;;
esac
