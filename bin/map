#!/usr/bin/env bash
# map — Multi-AI Platform CLI v0.2.0
# Usage: map <command> [args]
#
# Commands:
#   init [path]                    Initialize a workspace + auto-configure hooks
#   start <client> [task]          Start an LLM session with tracking
#   hook start <client>            (Internal) Called by CLI SessionStart hooks
#   hook end <client>              (Internal) Called by CLI SessionEnd hooks
#   hook continue <session_id>     Continue a session from another CLI
#   status                         Show active sessions and wiki stats
#   sync                           Re-inject protocol into config files

set -euo pipefail

MAP_VERSION="0.3.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE_DIR="$(cd "$SCRIPT_DIR/../templates" && pwd)"

# --- Colors (stderr only for hooks — stdout is for LLM context) ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_ok()   { echo -e "${GREEN}[OK]${NC}   $1" >&2; }
log_info() { echo -e "${CYAN}[INFO]${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_err()  { echo -e "${RED}[ERR]${NC}  $1" >&2; }

# --- Helpers ---
client_name() {
    case "$1" in
        claude) echo "Claude Code" ;;
        gemini) echo "Gemini CLI" ;;
        codex)  echo "Codex CLI" ;;
        slack)  echo "Slack Bot" ;;
        *)      echo "$1" ;;
    esac
}

make_session_id() {
    echo "${1}-$(date +%Y%m%d-%H%M)"
}

ensure_sessions_md() {
    if [ ! -f "SESSIONS.md" ]; then
        cp "$TEMPLATE_DIR/SESSIONS.md" "SESSIONS.md"
    fi
}

ensure_sessions_dir() {
    mkdir -p sessions
}

# --- Stale cleanup (>2h) ---
cleanup_stale() {
    [ ! -f "SESSIONS.md" ] && return 0
    local now_epoch year stale_ids=""
    now_epoch=$(date +%s)
    year=$(date +%Y)

    # Find stale session IDs
    for sid in $(grep "^| [a-z]" "SESSIONS.md" 2>/dev/null | awk -F'|' '{print $2}' | tr -d ' '); do
        local last_update
        last_update=$(grep "^| ${sid} " "SESSIONS.md" | awk -F'|' '{print $5}' | tr -d ' ')
        [ -z "$last_update" ] && continue
        local epoch
        epoch=$(date -j -f "%Y-%m-%d %H:%M" "${year}-${last_update}" +%s 2>/dev/null || echo "0")
        if [ "$epoch" -gt 0 ] && [ $((now_epoch - epoch)) -gt 7200 ]; then
            stale_ids="${stale_ids} ${sid}"
            # Mark session file as interrupted
            if [ -f "sessions/${sid}.md" ]; then
                sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: interrupted/' "sessions/${sid}.md" 2>/dev/null || true
                sed -i '' "s/^- \*\*Ended\*\*: (active)/- **Ended**: $(date '+%Y-%m-%d %H:%M') (stale)/" "sessions/${sid}.md" 2>/dev/null || true
            fi
        fi
    done

    # Remove stale entries
    if [ -n "$stale_ids" ]; then
        local tmp="SESSIONS.md.tmp"
        cp "SESSIONS.md" "$tmp"
        for sid in $stale_ids; do
            grep -v "^| ${sid} " "$tmp" > "${tmp}.2" 2>/dev/null || true
            mv "${tmp}.2" "$tmp"
        done
        mv "$tmp" "SESSIONS.md"
        log_info "Cleaned stale sessions:${stale_ids}"
    fi
    return 0
}

# ============================================================
# map init (v2 — includes hook auto-registration)
# ============================================================
cmd_init() {
    local target="${1:-.}"
    if [ ! -d "$target" ]; then
        mkdir -p "$target"
    fi
    target="$(cd "$target" && pwd)"

    echo -e "${CYAN}Multi-AI Platform v${MAP_VERSION}${NC}" >&2
    echo "Initializing workspace at: $target" >&2
    echo "" >&2

    # 1. SESSIONS.md
    if [ ! -f "$target/SESSIONS.md" ]; then
        cp "$TEMPLATE_DIR/SESSIONS.md" "$target/SESSIONS.md"
        log_ok "SESSIONS.md created"
    else
        log_warn "SESSIONS.md already exists, skipping"
    fi

    # 2. sessions/ directory
    mkdir -p "$target/sessions"
    log_ok "sessions/ directory created"

    # 3. wiki/
    if [ ! -d "$target/wiki" ]; then
        mkdir -p "$target/wiki/topics"
        cp "$TEMPLATE_DIR/wiki/Index.md" "$target/wiki/Index.md"
        cp "$TEMPLATE_DIR/wiki/Log.md" "$target/wiki/Log.md"
        log_ok "wiki/ directory created"
    else
        log_warn "wiki/ already exists, skipping"
    fi

    # 4. .gitignore
    local gitignore="$target/.gitignore"
    local needs_update=false
    if [ -f "$gitignore" ]; then
        grep -q "^SESSIONS.md$" "$gitignore" || needs_update=true
    else
        needs_update=true
    fi
    if $needs_update; then
        echo -e "\n# MAP (ephemeral session index)\nSESSIONS.md" >> "$gitignore"
        log_ok "Updated .gitignore (SESSIONS.md)"
    fi

    # 5. Inject protocol
    inject_protocol "$target"

    # 6. Auto-configure CLI hooks
    echo "" >&2
    configure_hooks

    echo "" >&2
    log_ok "Workspace initialized!"
    echo "" >&2
    echo "Usage:" >&2
    echo "  map start claude \"your task\"    Start a tracked session" >&2
    echo "  map status                       Show active sessions" >&2
    echo "  map hook continue <session_id>   Continue another session" >&2
}

# ============================================================
# Hook auto-configuration
# ============================================================
configure_hooks() {
    log_info "Detecting installed CLIs and configuring hooks..."

    # Claude Code
    if command -v claude &>/dev/null; then
        local claude_settings="$HOME/.claude/settings.json"
        if [ -f "$claude_settings" ]; then
            if grep -q "map hook" "$claude_settings" 2>/dev/null; then
                log_warn "Claude hooks already configured"
            else
                # Use jq to add hooks if available, otherwise inform user
                if command -v jq &>/dev/null; then
                    local tmp="${claude_settings}.tmp"
                    jq '.hooks = (.hooks // {}) |
                        .hooks.SessionStart = (.hooks.SessionStart // []) + [{"matcher": "", "hooks": [{"type": "command", "command": "map hook start claude"}]}] |
                        .hooks.SessionEnd = (.hooks.SessionEnd // []) + [{"matcher": "", "hooks": [{"type": "command", "command": "map hook end claude"}]}]' \
                        "$claude_settings" > "$tmp" && mv "$tmp" "$claude_settings"
                    log_ok "Claude Code hooks configured (SessionStart + SessionEnd)"
                else
                    log_warn "jq not found — add Claude hooks manually to ~/.claude/settings.json"
                fi
            fi
        else
            log_warn "~/.claude/settings.json not found"
        fi
    else
        log_info "Claude Code not installed, skipping"
    fi

    # Gemini CLI
    if command -v gemini &>/dev/null; then
        local gemini_settings="$HOME/.gemini/settings.json"
        if [ -f "$gemini_settings" ]; then
            if grep -q "map hook" "$gemini_settings" 2>/dev/null; then
                log_warn "Gemini hooks already configured"
            else
                if command -v jq &>/dev/null; then
                    local tmp="${gemini_settings}.tmp"
                    jq '.hooks = (.hooks // {}) |
                        .hooks.SessionStart = [{"matcher": "startup", "hooks": [{"name": "map-session-start", "type": "command", "command": "map hook start gemini"}]}] |
                        .hooks.SessionEnd = [{"matcher": "exit", "hooks": [{"name": "map-session-end", "type": "command", "command": "map hook end gemini"}]}]' \
                        "$gemini_settings" > "$tmp" && mv "$tmp" "$gemini_settings"
                    log_ok "Gemini CLI hooks configured (SessionStart + SessionEnd)"
                else
                    log_warn "jq not found — add Gemini hooks manually to ~/.gemini/settings.json"
                fi
            fi
        else
            log_warn "~/.gemini/settings.json not found"
        fi
    else
        log_info "Gemini CLI not installed, skipping"
    fi

    # Codex CLI
    if command -v codex &>/dev/null; then
        log_warn "Codex CLI: no SessionEnd hook support — use 'map start codex' wrapper for session tracking"
    else
        log_info "Codex CLI not installed, skipping"
    fi
}

# ============================================================
# Protocol injection
# ============================================================
PROTOCOL_MARKER="<!-- MAP:SESSION-MEMORY-PROTOCOL -->"
PROTOCOL_MARKER_END="<!-- MAP:END -->"

inject_protocol() {
    local target="$1"
    local protocol_file="$TEMPLATE_DIR/session-memory-protocol.md"

    for config_file in CLAUDE.md GEMINI.md AGENTS.md; do
        local fpath="$target/$config_file"

        if [ ! -f "$fpath" ]; then
            { echo "$PROTOCOL_MARKER"; cat "$protocol_file"; echo "$PROTOCOL_MARKER_END"; } > "$fpath"
            log_ok "Created $config_file with protocol"
        elif grep -q "$PROTOCOL_MARKER" "$fpath"; then
            local tmp="${fpath}.tmp"
            sed -n "1,/^${PROTOCOL_MARKER}$/{ /^${PROTOCOL_MARKER}$/!p; }" "$fpath" > "$tmp"
            echo "$PROTOCOL_MARKER" >> "$tmp"
            cat "$protocol_file" >> "$tmp"
            echo "$PROTOCOL_MARKER_END" >> "$tmp"
            sed -n "/^${PROTOCOL_MARKER_END}$/,\${ /^${PROTOCOL_MARKER_END}$/!p; }" "$fpath" >> "$tmp"
            mv "$tmp" "$fpath"
            log_ok "Updated protocol in $config_file"
        else
            { echo ""; echo "$PROTOCOL_MARKER"; cat "$protocol_file"; echo "$PROTOCOL_MARKER_END"; } >> "$fpath"
            log_ok "Appended protocol to $config_file"
        fi
    done
}

# ============================================================
# map hook start <client> — Called by CLI SessionStart hooks
# ============================================================
cmd_hook_start() {
    local client="${1:-unknown}"
    local cname
    cname=$(client_name "$client")
    local session_id
    session_id=$(make_session_id "$client")
    local started
    started="$(date '+%Y-%m-%d %H:%M')"
    local started_short
    started_short="$(date '+%m-%d %H:%M')"

    ensure_sessions_md
    ensure_sessions_dir
    cleanup_stale

    # Register in SESSIONS.md
    echo "| ${session_id} | ${cname} | ${started_short} | ${started_short} | (starting) |" >> "SESSIONS.md"
    log_info "Session registered: ${session_id}"

    # Create session context file
    local ctx_file="sessions/${session_id}.md"
    sed -e "s|{{SESSION_ID}}|${session_id}|g" \
        -e "s|{{CLIENT_NAME}}|${cname}|g" \
        -e "s|{{STARTED}}|${started}|g" \
        -e "s|{{TASK}}|(pending)|g" \
        "$TEMPLATE_DIR/session-context.md" > "$ctx_file"
    log_info "Session context: ${ctx_file}"

    # Export session ID for the CLI to use
    if [ -n "${CLAUDE_ENV_FILE:-}" ]; then
        echo "MAP_SESSION_ID=${session_id}" >> "$CLAUDE_ENV_FILE"
    fi

    # Check for previous sessions with empty Wiki Extractions
    for prev_file in $(ls -t sessions/*.md 2>/dev/null | head -5); do
        [ "$prev_file" = "sessions/${session_id}.md" ] && continue
        if grep -q "## Wiki Extractions" "$prev_file" && ! grep -A1 "## Wiki Extractions" "$prev_file" | grep -q "^- "; then
            local prev_status
            prev_status=$(grep "^\- \*\*Status\*\*:" "$prev_file" | sed 's/.*: //' || true)
            if [ "$prev_status" = "completed" ] || [ "$prev_status" = "interrupted" ]; then
                echo "[MAP] Previous session $(basename "$prev_file" .md) has no Wiki Extractions."
                echo "[MAP] Review it and extract wiki-worthy knowledge if any."
                echo ""
            fi
        fi
    done

    # Output other active/recent sessions for LLM context (stdout → LLM)
    local other_sessions
    other_sessions=$(grep "^| " "SESSIONS.md" | grep -v "Session ID\|---\|${session_id}" || true)
    if [ -n "$other_sessions" ]; then
        echo "[MAP] Other active sessions:"
        echo "$other_sessions"
        echo ""
    fi

    # Output most recent interrupted/completed session for continuity
    local latest
    latest=$(ls -t sessions/*.md 2>/dev/null | grep -v "${session_id}" | head -1 || true)
    if [ -n "$latest" ] && [ -f "$latest" ]; then
        local status
        status=$(grep "^\- \*\*Status\*\*:" "$latest" | head -1 || true)
        if echo "$status" | grep -q "active\|interrupted"; then
            echo "[MAP] Recent session available for continuation:"
            echo "  File: $latest"
            head -20 "$latest"
            echo "..."
            echo ""
            echo "To continue this session, the LLM should read sessions/$(basename "$latest") and update its own session file."
        fi
    fi
}

# ============================================================
# map hook end <client> — Called by CLI SessionEnd hooks
# ============================================================
cmd_hook_end() {
    local client="${1:-unknown}"

    # Find this client's active session in SESSIONS.md
    local session_id
    session_id=$(grep "^| ${client}-" "SESSIONS.md" 2>/dev/null | tail -1 | awk -F'|' '{print $2}' | tr -d ' ' || true)

    if [ -z "$session_id" ]; then
        log_warn "No active session found for ${client}"
        return
    fi

    # Remove from SESSIONS.md
    local tmp="SESSIONS.md.tmp"
    grep -v "^| ${session_id} " "SESSIONS.md" > "$tmp" 2>/dev/null || true
    mv "$tmp" "SESSIONS.md"
    log_info "Session unregistered: ${session_id}"

    # Update session file status
    local ctx_file="sessions/${session_id}.md"
    if [ -f "$ctx_file" ]; then
        sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: completed/' "$ctx_file" 2>/dev/null || true
        sed -i '' "s/^- \*\*Ended\*\*: (active)/- **Ended**: $(date '+%Y-%m-%d %H:%M')/" "$ctx_file" 2>/dev/null || true

        # Auto-generate summary from Log entries
        local log_count
        log_count=$(grep -c "^- \[" "$ctx_file" 2>/dev/null || echo "0")
        local decisions_count
        decisions_count=$(sed -n '/^## Decisions/,/^## /{/^- /p;}' "$ctx_file" 2>/dev/null | wc -l | tr -d ' ')
        local blockers_count
        blockers_count=$(sed -n '/^## Blockers/,/^## /{/^- /p;}' "$ctx_file" 2>/dev/null | wc -l | tr -d ' ')
        local task
        task=$(grep "^\- \*\*Task\*\*:" "$ctx_file" | sed 's/.*: //' || echo "unknown")

        # Append auto-summary at the end
        {
            echo ""
            echo "## Summary (auto-generated)"
            echo "- Task: ${task}"
            echo "- Log entries: ${log_count}, Decisions: ${decisions_count}, Blockers: ${blockers_count}"
            echo "- Duration: $(grep '^\- \*\*Started\*\*:' "$ctx_file" | sed 's/.*: //') ~ $(date '+%Y-%m-%d %H:%M')"
        } >> "$ctx_file"

        log_info "Session marked completed: ${ctx_file} (${log_count} log entries)"
    fi
}

# ============================================================
# map hook continue <session_id> — Continue another session
# ============================================================
cmd_hook_continue() {
    local target_id="${1:-}"

    if [ -z "$target_id" ]; then
        log_err "Usage: map hook continue <session_id>"
        # List available sessions
        echo "Available sessions:" >&2
        ls -t sessions/*.md 2>/dev/null | while read -r f; do
            local name status
            name=$(basename "$f" .md)
            status=$(grep "^\- \*\*Status\*\*:" "$f" | sed 's/.*: //' || echo "unknown")
            echo "  $name ($status)" >&2
        done
        exit 1
    fi

    local ctx_file="sessions/${target_id}.md"
    if [ ! -f "$ctx_file" ]; then
        log_err "Session file not found: ${ctx_file}"
        exit 1
    fi

    # Output full session context (stdout → LLM)
    echo "[MAP] Continuing session: ${target_id}"
    echo ""
    cat "$ctx_file"
    echo ""
    echo "[MAP] Please continue the work described above. Update your session file with new progress."
}

# ============================================================
# map start <client> [task] — User-facing wrapper
# ============================================================
cmd_start() {
    local client="${1:-}"
    local task="${2:-}"

    if [ -z "$client" ]; then
        log_err "Usage: map start <claude|gemini|codex> [task description]"
        exit 1
    fi

    local cname
    cname=$(client_name "$client")
    local session_id
    session_id=$(make_session_id "$client")
    local started
    started="$(date '+%Y-%m-%d %H:%M')"
    local started_short
    started_short="$(date '+%m-%d %H:%M')"
    local task_desc="${task:-진행 중}"

    ensure_sessions_md
    ensure_sessions_dir

    # Register
    echo "| ${session_id} | ${cname} | ${started_short} | ${started_short} | ${task_desc} |" >> "SESSIONS.md"

    # Create session context file
    local ctx_file="sessions/${session_id}.md"
    sed -e "s|{{SESSION_ID}}|${session_id}|g" \
        -e "s|{{CLIENT_NAME}}|${cname}|g" \
        -e "s|{{STARTED}}|${started}|g" \
        -e "s|{{TASK}}|${task_desc}|g" \
        "$TEMPLATE_DIR/session-context.md" > "$ctx_file"

    log_info "Session registered: ${session_id} — ${task_desc}"
    log_info "Context file: ${ctx_file}"

    # Trap for cleanup
    cleanup() {
        if [ -f "SESSIONS.md" ]; then
            local tmp="SESSIONS.md.tmp"
            grep -v "^| ${session_id} " "SESSIONS.md" > "$tmp" 2>/dev/null || true
            mv "$tmp" "SESSIONS.md"
        fi
        if [ -f "$ctx_file" ]; then
            sed -i '' 's/^- \*\*Status\*\*: active/- **Status**: completed/' "$ctx_file" 2>/dev/null || true
        fi
        log_info "Session unregistered: ${session_id}"
    }
    trap cleanup EXIT

    exec "$client"
}

# ============================================================
# map status
# ============================================================
cmd_status() {
    echo -e "${CYAN}Multi-AI Platform Status${NC}" >&2
    echo "" >&2

    # Sessions
    if [ -f "SESSIONS.md" ]; then
        local count
        count=$(grep -c "^| [a-z]" SESSIONS.md 2>/dev/null || echo "0")
        echo -e "Sessions: ${GREEN}${count} active${NC}" >&2
        if [ "$count" -gt 0 ]; then
            grep "^| [a-z]" SESSIONS.md >&2
        fi
    else
        echo -e "Sessions: ${YELLOW}SESSIONS.md not found${NC}" >&2
    fi

    # Session files
    if [ -d "sessions" ]; then
        local total active completed interrupted
        total=$(find sessions -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        active=$(grep -rl "Status.*active" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        completed=$(grep -rl "Status.*completed" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        interrupted=$(grep -rl "Status.*interrupted" sessions/*.md 2>/dev/null | wc -l | tr -d ' ')
        echo -e "Session files: ${total} total (${GREEN}${active} active${NC}, ${completed} completed, ${YELLOW}${interrupted} interrupted${NC})" >&2
    fi

    echo "" >&2

    # Wiki
    if [ -d "wiki/topics" ]; then
        local topics
        topics=$(find wiki/topics -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "Wiki: ${GREEN}${topics} topics${NC}" >&2
        if [ -f "wiki/Index.md" ]; then
            grep "^|" wiki/Index.md | grep -v "Topic\|---" 2>/dev/null >&2 || true
        fi
    else
        echo -e "Wiki: ${YELLOW}not initialized${NC}" >&2
    fi
}

# ============================================================
# map sync
# ============================================================
cmd_sync() {
    inject_protocol "."
    log_ok "Protocol synced to all config files"
}

# ============================================================
# Main
# ============================================================
case "${1:-}" in
    init)    shift; cmd_init "$@" ;;
    start)   shift; cmd_start "$@" ;;
    hook)
        shift
        case "${1:-}" in
            start)    shift; cmd_hook_start "$@" ;;
            end)      shift; cmd_hook_end "$@" ;;
            continue) shift; cmd_hook_continue "$@" ;;
            *)        log_err "Usage: map hook <start|end|continue> [args]"; exit 1 ;;
        esac
        ;;
    status)  cmd_status ;;
    sync)    cmd_sync ;;
    version) echo "map v${MAP_VERSION}" ;;
    -h|--help|help|"")
        echo "map — Multi-AI Platform CLI v${MAP_VERSION}"
        echo ""
        echo "Commands:"
        echo "  init [path]                    Initialize workspace + configure hooks"
        echo "  start <client> [task]          Start LLM session with tracking"
        echo "  hook start <client>            (Auto) Called by CLI SessionStart hooks"
        echo "  hook end <client>              (Auto) Called by CLI SessionEnd hooks"
        echo "  hook continue <session_id>     Continue another CLI's session"
        echo "  status                         Show active sessions and wiki"
        echo "  sync                           Re-inject protocol into config files"
        echo "  version                        Show version"
        ;;
    *)
        log_err "Unknown command: $1"
        echo "Run 'map --help' for usage"
        exit 1
        ;;
esac
